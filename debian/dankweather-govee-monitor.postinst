#!/bin/sh
set -e

case "$1" in
    configure)
        # The conf file may contain a provisioning key, so restrict reads to
        # root and the service group (the unit runs as nobody:nogroup).
        if [ -f /etc/dankweather-govee-monitor.conf ]; then
            chown root:nogroup /etc/dankweather-govee-monitor.conf || true
            chmod 0640 /etc/dankweather-govee-monitor.conf || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
